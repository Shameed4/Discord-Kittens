# Discord application credentials (https://discord.com/developers/applications).
# Copy this file to .env and fill in your app's values.

# Discord OAuth2 client id. Exposed to the frontend (VITE_ prefix), used by the
# embedded-app SDK handshake.
VITE_DISCORD_CLIENT_ID=your_discord_app_client_id

# Discord OAuth2 client secret. Backend-only; used by /token to exchange an
# authorization code for an access token. Keep this out of version control.
DISCORD_CLIENT_SECRET=your_discord_app_client_secret
