{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend (Go)",
      "type": "shell",
      "command": "go run .",
      "options": { "cwd": "${workspaceFolder}/game" },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "group": "dev", "panel": "dedicated", "reveal": "always" }
    },
    {
      "label": "Frontend (Vite)",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/client" },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "group": "dev", "panel": "dedicated", "reveal": "always" }
    },
    {
      "label": "Cloudflared Tunnel",
      "type": "shell",
      "windows": {
        "command": "cloudflared tunnel --url http://localhost:5173 2>&1 | ForEach-Object { $_; if ($_ -match 'https://[a-z0-9-]+\\.trycloudflare\\.com') { Set-Clipboard $matches[0]; Write-Host ('=== Tunnel URL copied to clipboard: ' + $matches[0]) -ForegroundColor Green } }",
        "options": { "shell": { "executable": "powershell.exe", "args": ["-NoProfile", "-Command"] } }
      },
      "osx": {
        "command": "cloudflared tunnel --url http://localhost:5173 2>&1 | while IFS= read -r line; do echo \"$line\"; url=$(echo \"$line\" | grep -oE 'https://[a-z0-9-]+\\.trycloudflare\\.com'); if [ -n \"$url\" ]; then printf '%s' \"$url\" | pbcopy; echo \"=== Tunnel URL copied to clipboard: $url\"; fi; done",
        "options": { "shell": { "executable": "/bin/bash", "args": ["-c"] } }
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "group": "dev", "panel": "dedicated", "reveal": "always" }
    },
    {
      "label": "Dev: All (Frontend + Backend + Tunnel)",
      "dependsOn": ["Backend (Go)", "Frontend (Vite)", "Cloudflared Tunnel"],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "group": { "kind": "build", "isDefault": true }
    }
  ]
}
