{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Go Server",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/game",
      "cwd": "${workspaceFolder}/game"
    },
    {
      "name": "Run Frontend (Vite)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/client",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "Run Frontend + Backend",
      "configurations": ["Debug Go Server", "Run Frontend (Vite)"],
      "stopAll": true
    }
  ]
}
